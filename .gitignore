# ─────────────────────────────────────────────────────────────────────────────
# JobHunt Monorepo — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ─── Dependencies ─────────────────────────────────────────────────────────────
# Match node_modules anywhere in the repo (frontend/, backend/, root)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Environment Variables ────────────────────────────────────────────────────
# NEVER commit secrets. Use .env.example for templates.
.env
.env.*
!.env.example    # allow committing the template

# ─── Next.js (frontend/) ──────────────────────────────────────────────────────
.next/
out/
next-env.d.ts

# ─── Build Outputs ────────────────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─── Test Coverage ────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
*.pem
.idea/
.vscode/
*.swp
*.swo

# ─── Deployment ───────────────────────────────────────────────────────────────
.vercel

# ─── Claude Code ──────────────────────────────────────────────────────────────
# Keep these private — they contain project-specific AI instructions
CLAUDE.md
AGENTS.md
/.claude
