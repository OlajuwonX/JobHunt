// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema (prisma/schema.prisma)
// ─────────────────────────────────────────────────────────────────────────────
//
// This file defines the database structure. It's the single source of truth —
// Prisma reads this and generates:
//   1. SQL migrations (the actual database tables)
//   2. TypeScript types (so your code knows the shape of each table)
//
// WORKFLOW:
//   Edit this file → run `npm run db:migrate` → Prisma creates the SQL migration
//   and applies it to your database
//
// AFTER EDITING:
//   Always run: npm run db:generate
//   This regenerates the TypeScript types so your IDE/TypeScript is in sync.
//
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL comes from .env
  // Neon format: postgresql://user:pass@host.neon.tech/dbname?sslmode=require
  url      = env("DATABASE_URL")
}

// ─── User ──────────────────────────────────────────────────────────────────────
// Core authentication table. Keeps auth data separate from profile data
// so the auth layer stays simple.
model User {
  id           String   @id @default(cuid()) // cuid = collision-resistant unique ID
  email        String   @unique
  passwordHash String   // bcrypt hash — NEVER store plain passwords
  verified     Boolean  @default(false)  // must verify email before logging in
  verifyToken  String?  // email verification token (null after verified)
  resetToken   String?  // password reset token (future feature)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations — one user can have one profile and many applications
  profile      Profile?
  applications Application[]
  atsScores    AtsScore[]

  @@map("users") // the actual PostgreSQL table name
}

// ─── Profile ───────────────────────────────────────────────────────────────────
// User's job search preferences. This drives the matching engine —
// which jobs get shown and how they're scored.
model Profile {
  id         String   @id @default(cuid())
  userId     String   @unique  // one profile per user
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  resumeUrl  String?  // private Cloudinary URL (never expose the public URL)
  roles      String[] // e.g. ["Frontend Engineer", "React Developer"]
  location   String?  // e.g. "Lagos, Nigeria" or "New York, NY"
  remotePref String   @default("any") // remote | hybrid | onsite | any
  skills     String[] // e.g. ["React", "TypeScript", "Node.js"]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("profiles")
}

// ─── Job ───────────────────────────────────────────────────────────────────────
// Stores normalized job listings from all sources.
// job_hash prevents duplicate jobs from being stored multiple times.
model Job {
  id           String   @id @default(cuid())

  // Hash of (title + company + location) — used to detect duplicates.
  // If Greenhouse and Lever both list the same job, jobHash will be the same
  // and we upsert instead of creating two records.
  jobHash      String   @unique

  title        String
  company      String
  source       String   // "greenhouse" | "lever"
  location     String?
  remote       Boolean  @default(false)
  description  String   @db.Text  // can be very long
  requirements String[] // bullet-pointed requirements extracted from description
  techStack    String[] // tech tags extracted (React, Node.js, PostgreSQL, etc.)
  applyUrl     String
  postedAt     DateTime
  createdAt    DateTime @default(now())

  // Relations
  applications Application[]
  atsScores    AtsScore[]

  @@index([source])     // index for filtering by source
  @@index([postedAt])   // index for sorting by date
  @@map("jobs")
}

// ─── Application ───────────────────────────────────────────────────────────────
// Tracks which jobs a user has applied to (or saved, rejected, etc.)
// This is a join table between User and Job with extra metadata.
model Application {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Application status — drives the filter and dashboard stats
  status    String   @default("applied") // applied | saved | rejected | offer

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Prevent a user from having two application records for the same job
  @@unique([userId, jobId])
  @@index([userId])      // fast lookup of all applications for a user
  @@index([status])      // fast filter by status
  @@map("applications")
}

// ─── ATS Score ─────────────────────────────────────────────────────────────────
// Stores the AI-generated ATS match score for a user+job combination.
// Scoring happens asynchronously (cron job) so we cache the result here
// instead of calling PuterJS on every job detail request.
model AtsScore {
  id          String   @id @default(cuid())
  userId      String
  jobId       String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  score       Int      // 0–100
  suggestions String[] // actionable tips: "Add TypeScript to your skills section"

  scoredAt    DateTime @default(now())

  @@unique([userId, jobId]) // one score per user+job pair
  @@map("ats_scores")
}
