// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema (prisma/schema.prisma)
// ─────────────────────────────────────────────────────────────────────────────
//
// This file is the SINGLE SOURCE OF TRUTH for your database structure.
// Prisma reads it and generates:
//   1. SQL migrations  → the actual tables in PostgreSQL
//   2. TypeScript types → so your code is type-safe when reading/writing data
//
// WORKFLOW (every time you change this file):
//   npm run db:migrate   → creates + applies a SQL migration
//   npm run db:generate  → regenerates TypeScript types from schema
//   npm run db:studio    → opens a browser UI to view your data (TablePlus alternative)
//
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // DATABASE_URL is read from your .env file
  // Neon format: postgresql://user:pass@host.neon.tech/dbname?sslmode=require
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────
// The core identity table. Only stores authentication data.
// Profile data (skills, location, etc.) is in the Profile table.
// Why separate? Auth stays simple and doesn't get bloated with preference data.
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id String @id @default(cuid())
  // cuid() = collision-resistant unique ID — safer than sequential numbers
  // (sequential IDs leak how many users you have, e.g. /users/4 means only 4 users)

  email        String @unique
  passwordHash String
  // NEVER store plain passwords. We use Argon2 to hash:
  // "mysecret" → "$argon2id$v=19$m=65536,t=3,p=4$..." (irreversible)

  verified Boolean @default(false)
  // Account starts unverified. User must click email link before they can log in.

  verifyToken String?
  // Random token sent in the verification email. Null once account is verified.

  verifyTokenExp DateTime?
  // Verification token expires after 24 hours for security.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Relations ──────────────────────────────────────────────────────────────
  // These are not columns — they're Prisma's way of expressing SQL foreign keys.
  // When you do: prisma.user.findUnique({ include: { profile: true } })
  // Prisma joins the tables for you automatically.
  profile      Profile?
  sessions     Session[]
  applications Application[]
  atsScores    AtsScore[]
  authLogs     AuthLog[]

  @@map("users") // the actual PostgreSQL table name (snake_case convention)
}

// ─────────────────────────────────────────────────────────────────────────────
// SESSION
// ─────────────────────────────────────────────────────────────────────────────
// Tracks every active login session for a user.
//
// WHY DO WE NEED THIS?
//   JWTs alone are stateless — once issued, you can't revoke them.
//   If someone steals a token, they can use it until it expires.
//
//   Sessions give us server-side control:
//   - We can revoke a session instantly (logout, suspicious activity)
//   - We can show users "you're logged in from Chrome on Windows"
//   - We detect stolen refresh tokens via rotation (see auth.service.ts)
//
// HOW REFRESH TOKEN ROTATION WORKS:
//   1. User logs in → we create a Session with a hashed refresh token
//   2. Access token expires (5 min) → frontend sends the refresh token cookie
//   3. We find the session, verify the token, issue a NEW access + refresh token
//   4. The old refresh token is marked used/replaced
//   5. If someone tries to reuse an old token → we detect it → revoke ALL sessions
// ─────────────────────────────────────────────────────────────────────────────
model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String   @unique
  // We NEVER store the raw refresh token. We hash it with SHA-256.
  // Even if the database is compromised, the attacker can't use the tokens.
  // @unique: one hash = one session. Also enables findUnique() in the service.

  userAgent String?
  // e.g. "Mozilla/5.0 (Windows NT 10.0; Win64; x64)..."
  // Stored to help users identify which device this session belongs to.

  ipAddress String?
  // The user's IP address at login time. Used for anomaly detection.

  expiresAt DateTime
  // Absolute expiry — after this date the session is dead regardless of activity.
  // Typically 30 days from creation.

  revoked Boolean @default(false)
  // If true, this session has been invalidated (logout, suspicious activity, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId]) // fast lookup: "get all sessions for this user"
  // @@index([refreshTokenHash]) removed — @unique on the field already creates an index
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROFILE
// ─────────────────────────────────────────────────────────────────────────────
// User's job search preferences. This is the engine of personalization.
// The matching algorithm reads this to decide which jobs to surface.
// ─────────────────────────────────────────────────────────────────────────────
model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // onDelete: Cascade — if the user is deleted, their profile is too (no orphans)

  resumeUrl String?
  // Private Cloudinary signed URL. NEVER expose the raw Cloudinary public URL.
  // Signed URLs expire — we regenerate them on each profile request.

  roles String[]
  // What job titles the user is looking for.
  // e.g. ["Frontend Engineer", "React Developer", "UI Engineer"]

  location String?
  // e.g. "Lagos, Nigeria" — used to filter and rank nearby jobs.

  remotePref String @default("any")
  // How the user wants to work: "remote" | "hybrid" | "onsite" | "any"

  skills String[]
  // Tech skills for ATS scoring.
  // e.g. ["React", "TypeScript", "Node.js", "PostgreSQL"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// JOB
// ─────────────────────────────────────────────────────────────────────────────
// Stores normalized job listings aggregated from external sources.
// All jobs go through a normalizer before being saved here, so the data
// shape is consistent regardless of whether it came from Greenhouse or Lever.
// ─────────────────────────────────────────────────────────────────────────────
model Job {
  id String @id @default(cuid())

  jobHash String @unique
  // SHA-256 hash of (title + company + location) — exact match deduplication.
  // Two jobs with the same title, company, and location from any source → same hash → stored once.

  fuzzyHash String?
  // SHA-256 hash of (canonicalTitle + canonicalCompany + canonicalLocation).
  // FUZZY DEDUPLICATION: catches title variants that refer to the same role:
  //   "Frontend Engineer" ≈ "Frontend Developer" ≈ "Front-End Engineer"
  //   "Junior Developer"  ≈ "Jr. Developer" ≈ "Jnr Developer"
  // Nullable so existing rows without a fuzzyHash are harmless (treated as unscored).
  // NOT @unique — uniqueness is enforced in the service layer (batchUpsert),
  // not the DB, because false-positive collisions on fuzzyHash are possible and
  // we handle them with a pre-check + createMany rather than a DB constraint.

  title   String
  company String
  source  String
  // Which platform this job came from:
  // "greenhouse" | "lever" | "wellfound" | "weworkremotely" | "indeed" | "linkedin"

  location     String?
  remote       Boolean  @default(false)
  description  String   @db.Text // @db.Text = no length limit (descriptions can be long)
  requirements String[] // bullet-pointed requirements extracted from the description
  techStack    String[] // tech tags we extract: ["React", "Node.js", "AWS", ...]
  applyUrl     String // the actual application link

  sourceUrl   String?
  // The original listing page URL — sometimes different from applyUrl.
  // Example: on Jobberman the listing is /jobs/slug but apply redirects to external site.
  // We store both so users can always reach the listing even if the apply URL breaks.

  salaryRange String?
  // Human-readable salary string as the source provides it.
  // e.g. "$80,000 - $120,000" or "£50k–£70k" or null if not specified.
  // We store it as-is (not parsed to numbers) because formats vary wildly across sources.

  category  String   @default("other")
  // Detected from title+description during normalization.
  // Values: 'tech' | 'finance' | 'sales' | 'marketing' | 'healthcare' | 'design' | 'operations' | 'hr' | 'legal' | 'education' | 'other'
  // Enables category-based filtering on the job feed (e.g. "show me only tech jobs").

  country   String   @default("global")
  // Detected from location string + source name during normalization.
  // Values: 'nigeria' | 'global' — lowercase only for consistent query comparison.
  // Allows Nigerian users to see more locally-relevant jobs at the top of their feed.

  postedAt  DateTime // when the job was posted on the source platform
  createdAt DateTime @default(now())

  // Relations
  applications Application[]
  atsScores    AtsScore[]

  @@index([source])              // fast filter: show me only Greenhouse jobs
  @@index([postedAt(sort: Desc)]) // fast sort: newest first
  @@index([remote])              // fast filter: remote jobs only
  @@index([fuzzyHash])           // fast lookup during batchUpsert fuzzy dedup pre-check
  @@index([category])            // fast filter: show me only tech jobs
  @@index([country])             // fast filter: show me only Nigerian jobs
  @@map("jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// APPLICATION
// ─────────────────────────────────────────────────────────────────────────────
// Tracks a user's interaction with a job.
// This is a "join table" — it connects User ↔ Job with extra data (status).
// ─────────────────────────────────────────────────────────────────────────────
model Application {
  id     String @id @default(cuid())
  userId String
  jobId  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  status String @default("applied")
  // Lifecycle states: "applied" → "rejected" | "offer"
  // Or "saved" (user bookmarked it but hasn't applied yet)

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // A user can only have ONE application record per job.
  // If they try to apply twice, Prisma throws a unique constraint error.

  @@unique([userId, jobId])
  @@index([userId]) // fast: "show me all applications for user X"
  @@index([status]) // fast: "show me all rejected applications"
  @@map("applications")
}

// ─────────────────────────────────────────────────────────────────────────────
// ATS SCORE
// ─────────────────────────────────────────────────────────────────────────────
// Caches the AI-generated resume-to-job match score.
// ATS = Applicant Tracking System — the software companies use to filter CVs.
//
// WHY CACHE IT?
//   Calling PuterJS (AI) is slow. We run scoring asynchronously via cron jobs
//   and store the result here. When the user opens a job, we return the cached
//   score instantly instead of waiting for AI.
// ─────────────────────────────────────────────────────────────────────────────
model AtsScore {
  id     String @id @default(cuid())
  userId String
  jobId  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  score Int
  // 0–100. Color coding on the frontend:
  // ≥70 = green (strong match), 40–69 = yellow (partial), <40 = red (weak)

  suggestions String[]
  // Actionable AI tips, e.g.:
  // ["Add 'TypeScript' to your skills", "Mention React in your summary"]

  scoredAt DateTime @default(now())

  @@unique([userId, jobId]) // one score per user+job pair
  @@map("ats_scores")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH LOG
// ─────────────────────────────────────────────────────────────────────────────
// Immutable audit trail of authentication events.
// Used for security monitoring, incident response, and anomaly detection.
// Never delete records from this table — it's an audit log.
// ─────────────────────────────────────────────────────────────────────────────
model AuthLog {
  id     String  @id @default(cuid())
  userId String?
  // Nullable — failed logins before account exists won't have a userId.
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  event String
  // Event types:
  //   "register"          — new account created
  //   "login_success"     — successful login
  //   "login_failed"      — wrong password
  //   "logout"            — user logged out
  //   "token_refreshed"   — access token refreshed
  //   "token_reuse"       — SECURITY: refresh token reused after rotation
  //   "email_verified"    — account verified via email link
  //   "sessions_revoked"  — all sessions killed (due to token reuse attack)

  ipAddress String?
  userAgent String?

  metadata Json?
  // Optional extra context — e.g. { "reason": "token reuse detected", "revokedCount": 3 }

  createdAt DateTime @default(now())

  @@index([userId]) // fast: "show me all auth events for user X"
  @@index([event]) // fast: "show me all login_failed events"
  @@index([createdAt]) // fast: "show me events from the last 24 hours"
  @@map("auth_logs")
}
